#!/usr/bin/env python3

import logging
import json
import argparse
import sys
import os
original_cwd = os.getcwd()
repo_root = os.path.abspath(os.path.join(os.path.dirname(__file__), '..', '..'))
sys.path.insert(0, repo_root)
os.chdir(repo_root)

from CHROMER import process_chrom

with open('./config.json', 'r') as f:
    config = json.load(f)
    
brain_path = config['paths']['brain']
with open(brain_path, 'r') as f:
    brain = json.load(f)

logging.basicConfig(level=logging.INFO)
parser = argparse.ArgumentParser(description='Debug tool for inspecting chromatographic data.')
parser.add_argument('zip_file', type=str, help='Path to the .Result file to inspect.')
args = parser.parse_args()

zip_file = args.zip_file
if not os.path.isabs(zip_file):
    zip_file = os.path.abspath(os.path.join(original_cwd, zip_file))

result = process_chrom(zip_file, brain)

print(json.dumps(result, indent=4))