# Python virtualenv (created by the Cursor Cloud update script)
.venv/

# Python bytecode
__pycache__/
*.py[cod]

# Google credentials (Google layer is out of scope for local dev; never commit)
dev/.rsc/*.json

# Proprietary UNICORN input data: in-scope to process locally, never committable
data/DROP-OFF/*
!data/DROP-OFF/.gitkeep

# Runtime output (timestamped run folders + logs; committed data/DONE/_sample/ stays tracked)
dev/debug/logs/
data/DONE/*/
!data/DONE/_sample/
